<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>What a website can actually do — a working demo</title>
<meta name="description" content="Live examples of interactive website components: filterable galleries, comparison sliders, instant pricing, conditional forms and layouts that hold up on every screen.">

<!--
=====================================================================
  All images are live from the Three Sixty Plus media library.
  To swap any of them, edit the GALLERY / COMPARE / DEVICE values
  in the CONFIG block at the bottom of this file.
=====================================================================
-->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,800&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
/* ============ NEUTRAL PALETTE — porcelain / ink / ultramarine ============ */
:root{
  --paper:#F4F5F7; --surface:#FFFFFF; --ink:#14181D; --slate:#5A6472;
  --hair:#DEE2E7; --accent:#2B4CF2; --accent-soft:rgba(43,76,242,.08);
  --radius:12px; --maxw:1140px;
}
[data-theme="dark"]{
  --paper:#0F1216; --surface:#171B21; --ink:#EDEFF2; --slate:#98A2B0;
  --hair:#262C34; --accent:#7C93FF; --accent-soft:rgba(124,147,255,.12);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:var(--paper);color:var(--ink);
  font-family:'Inter',system-ui,sans-serif;font-size:16px;line-height:1.6;
  -webkit-font-smoothing:antialiased;transition:background .3s ease,color .3s ease;
}
h1,h2,h3{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;line-height:1.05;letter-spacing:-.025em}
a{color:inherit;text-decoration:none}
button{font:inherit;cursor:pointer;border:0;background:none;color:inherit}
select{font:inherit}
img{display:block;width:100%;height:100%;object-fit:cover;background:var(--surface)}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 22px}
:focus-visible{outline:2px solid var(--accent);outline-offset:3px;border-radius:6px}
.mono{font-family:'JetBrains Mono',monospace;font-size:11.5px;letter-spacing:.12em;text-transform:uppercase}
.eyebrow{color:var(--accent);margin-bottom:14px;display:block}
section{padding:70px 0;border-top:1px solid var(--hair)}
@media(min-width:900px){section{padding:96px 0}}

/* section heading + the "who this is for" note that replaces a CTA */
.sec-head{max-width:60ch;margin-bottom:34px}
.sec-head h2{font-size:clamp(28px,4.4vw,44px)}
.sec-head p{color:var(--slate);margin-top:14px;font-size:17px}
.forwho{
  margin-top:26px;padding:20px 22px;
  background:var(--surface);border:1px solid var(--hair);
  border-left:4px solid var(--accent);border-radius:14px;
  display:flex;flex-wrap:wrap;gap:10px;align-items:center;
}
.forwho b{
  width:100%;font-family:'JetBrains Mono',monospace;font-weight:500;
  font-size:11px;letter-spacing:.14em;text-transform:uppercase;
  color:var(--accent);margin-bottom:2px;
}
.forwho span{
  border:1.5px solid var(--hair);border-radius:100px;padding:8px 16px;
  font-size:14px;font-weight:500;color:var(--ink);background:var(--paper);
}
[data-theme="dark"] .forwho span{background:var(--paper)}

/* ---------------- header ---------------- */
header{position:sticky;top:0;z-index:60;background:color-mix(in srgb,var(--paper) 88%,transparent);backdrop-filter:blur(14px);border-bottom:1px solid var(--hair)}
.nav{display:flex;align-items:center;justify-content:space-between;height:64px;gap:16px}
.brand{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:17px;letter-spacing:-.02em}
.brand i{font-style:normal;color:var(--accent)}
.nav-links{display:none;gap:24px;font-size:14.5px;color:var(--slate)}
.nav-links a:hover{color:var(--ink)}
@media(min-width:1000px){.nav-links{display:flex}}
.themeswitch{
  display:flex;gap:3px;padding:4px;flex:none;
  background:var(--surface);border:1.5px solid var(--hair);border-radius:100px;
}
.themeswitch button{
  display:flex;align-items:center;gap:6px;padding:7px 14px;border-radius:100px;
  font-size:13px;font-weight:500;color:var(--slate);transition:background .2s,color .2s;
}
.themeswitch button:hover{color:var(--ink)}
.themeswitch button[aria-pressed="true"]{background:var(--accent);color:#fff}
.themeswitch svg{width:14px;height:14px;flex:none}
@media(max-width:520px){.themeswitch button span{display:none}.themeswitch button{padding:8px 11px}}

/* ---------------- hero ---------------- */
.hero{padding:56px 0 74px;border-top:0}
.hero h1{font-size:clamp(38px,7.2vw,68px);max-width:15ch}
.hero .lead{color:var(--slate);font-size:18px;margin:22px 0 34px;max-width:56ch}

/* ---------------- responsive rig ---------------- */
.rig{background:var(--surface);border:1px solid var(--hair);border-radius:18px;padding:18px}
@media(min-width:900px){.rig{padding:26px}}
.rig-bar{display:flex;flex-wrap:wrap;align-items:center;gap:14px;margin-bottom:18px}
.rig-bar .mono{color:var(--slate)}
.rig-read{color:var(--accent)!important;font-weight:500}
.rig-presets{display:flex;gap:6px;margin-left:auto}
.rig-presets button{border:1px solid var(--hair);border-radius:100px;padding:6px 13px;font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:.08em;color:var(--slate)}
.rig-presets button[aria-pressed="true"]{background:var(--accent);border-color:var(--accent);color:#fff}
input[type=range]{-webkit-appearance:none;appearance:none;width:100%;height:3px;border-radius:3px;background:var(--hair);outline:none}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:22px;height:22px;border-radius:50%;background:var(--accent);cursor:ew-resize;border:3px solid var(--surface);box-shadow:0 2px 10px rgba(0,0,0,.18)}
input[type=range]::-moz-range-thumb{width:22px;height:22px;border-radius:50%;background:var(--accent);cursor:ew-resize;border:3px solid var(--surface)}
.rig-stage{margin-top:20px;display:flex;justify-content:center;background:var(--paper);border-radius:12px;padding:16px 12px;overflow:hidden}
.viewport{width:100%;max-width:100%;background:var(--surface);border:1px solid var(--hair);border-radius:10px;overflow:hidden;container-type:inline-size;transition:width .18s ease}

.mini-nav{display:flex;align-items:center;justify-content:space-between;padding:11px 14px;border-bottom:1px solid var(--hair)}
.mini-logo{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:12px}
.mini-menu{display:none;gap:14px;color:var(--slate);font-size:11px}
.mini-burger{display:flex;flex-direction:column;gap:3px}
.mini-burger i{width:16px;height:1.5px;background:var(--ink);display:block}
.mini-hero{display:grid;gap:14px;padding:16px 14px}
.mini-hero h4{font-family:'Bricolage Grotesque',sans-serif;font-size:19px;line-height:1.1;font-weight:800}
.mini-hero p{color:var(--slate);font-size:11.5px;margin-top:6px}
.mini-pill{display:inline-block;margin-top:10px;background:var(--accent);color:#fff;border-radius:100px;padding:7px 14px;font-size:11px}
.mini-img{aspect-ratio:1/1;border-radius:8px;overflow:hidden}
.mini-cards{display:grid;gap:10px;padding:0 14px 18px;grid-template-columns:1fr}
.mini-card{border:1px solid var(--hair);border-radius:8px;padding:11px}
.mini-card b{display:block;font-size:11.5px;font-weight:500}
.mini-card span{color:var(--slate);font-size:10.5px}
@container (min-width:560px){
  .mini-menu{display:flex}
  .mini-burger{display:none}
  .mini-hero{grid-template-columns:1.1fr .9fr;align-items:center;padding:26px 22px}
  .mini-hero h4{font-size:26px}
  .mini-img{aspect-ratio:1/1}
  .mini-cards{grid-template-columns:repeat(3,1fr);padding:0 22px 26px}
}
@container (min-width:900px){
  .mini-hero{padding:40px 30px;gap:30px}
  .mini-hero h4{font-size:34px}
  .mini-cards{padding:0 30px 34px;gap:14px}
}

.creds{display:flex;flex-wrap:wrap;gap:10px;margin-top:26px}
.chip{
  border:1.5px solid var(--hair);background:var(--surface);border-radius:100px;
  padding:10px 18px;font-size:14px;font-weight:500;color:var(--ink);
}
.chip b{color:var(--accent);font-weight:500}

/* ---------------- gallery ---------------- */
.filters{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px}
.filters button{border:1px solid var(--hair);border-radius:100px;padding:9px 17px;font-size:14px;color:var(--slate);transition:background .2s,color .2s,border-color .2s}
.filters button:hover{border-color:var(--accent);color:var(--accent)}
.filters button[aria-pressed="true"]{background:var(--ink);border-color:var(--ink);color:var(--paper)}
.gal{display:grid;gap:14px;grid-template-columns:repeat(2,1fr)}
@media(min-width:820px){.gal{grid-template-columns:repeat(3,1fr);gap:18px}}
.tile{border:1px solid var(--hair);border-radius:var(--radius);overflow:hidden;background:var(--surface);cursor:zoom-in;animation:pop .32s cubic-bezier(.2,.7,.3,1) backwards}
@keyframes pop{from{opacity:0;transform:translateY(10px) scale(.985)}to{opacity:1;transform:none}}
@media(prefers-reduced-motion:reduce){.tile{animation:none}}
.tile .frame{aspect-ratio:1/1;overflow:hidden}
.tile img{transition:transform .4s ease}
.tile:hover img{transform:scale(1.04)}
.tile figcaption{padding:12px 14px;display:flex;justify-content:space-between;gap:10px;align-items:baseline}
.tile figcaption b{font-weight:500;font-size:14px}
.tile figcaption span{color:var(--slate);font-size:11px}
.gal-note{margin-top:18px;color:var(--slate)}

.lb{position:fixed;inset:0;z-index:100;background:rgba(8,10,13,.92);display:none;align-items:center;justify-content:center;padding:24px}
.lb[open]{display:flex}
.lb figure{max-width:760px;width:100%}
.lb .frame{aspect-ratio:1/1;border-radius:12px;overflow:hidden}
.lb figcaption{color:#fff;margin-top:14px;display:flex;justify-content:space-between;font-size:14px}
.lb-close{position:absolute;top:18px;right:22px;color:#fff;font-size:28px;line-height:1}

/* ---------------- before / after ---------------- */
.ba{position:relative;border:1px solid var(--hair);border-radius:var(--radius);overflow:hidden;aspect-ratio:1/1;max-width:620px;margin:0 auto;background:var(--surface);touch-action:none}
@media(min-width:820px){.ba{aspect-ratio:4/3;max-width:820px}}
.ba .layer{position:absolute;inset:0}
.ba .layer.after{clip-path:inset(0 0 0 var(--split,50%))}
.ba-tag{position:absolute;bottom:14px;background:rgba(8,10,13,.72);color:#fff;padding:6px 12px;border-radius:100px;font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:.1em}
.ba-tag.l{left:14px}.ba-tag.r{right:14px}
.ba-handle{position:absolute;top:0;bottom:0;width:2px;background:#fff;left:var(--split,50%);pointer-events:none}
.ba-handle::after{content:"";position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:42px;height:42px;border-radius:50%;background:#fff;box-shadow:0 4px 20px rgba(0,0,0,.3)}
.ba input{position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:ew-resize;margin:0}

/* ---------------- panels, calculator, form ---------------- */
.two{display:grid;gap:20px}
@media(min-width:900px){.two{grid-template-columns:1.15fr .85fr;gap:26px;align-items:start}}
.panel{background:var(--surface);border:1px solid var(--hair);border-radius:16px;padding:22px}
@media(min-width:900px){.panel{padding:28px}}
.field-label{display:block;color:var(--slate);margin-bottom:12px}
.seg{display:flex;border:1px solid var(--hair);border-radius:100px;padding:4px;width:fit-content;margin-bottom:26px}
.seg button{padding:8px 18px;border-radius:100px;font-size:14px;color:var(--slate)}
.seg button[aria-pressed="true"]{background:var(--accent);color:#fff}
.plans{display:grid;gap:10px;margin-bottom:26px}
.plan{display:flex;align-items:center;gap:14px;border:1px solid var(--hair);border-radius:12px;padding:15px 16px;cursor:pointer;transition:border-color .2s,background .2s}
.plan:hover{border-color:var(--accent)}
.plan[data-on="1"]{border-color:var(--accent);background:var(--accent-soft)}
.plan .dot{width:17px;height:17px;border-radius:50%;border:2px solid var(--hair);flex:none;position:relative}
.plan[data-on="1"] .dot{border-color:var(--accent)}
.plan[data-on="1"] .dot::after{content:"";position:absolute;inset:3px;border-radius:50%;background:var(--accent)}
.plan .txt{flex:1}
.plan .txt b{display:block;font-weight:500;font-size:15px}
.plan .txt span{color:var(--slate);font-size:13px}
.plan .amt{font-family:'JetBrains Mono',monospace;font-size:14px;font-weight:500}
.addons{display:grid;gap:8px}
.addon{display:flex;align-items:center;gap:13px;border:1px solid var(--hair);border-radius:10px;padding:13px 15px;cursor:pointer}
.addon[data-on="1"]{border-color:var(--accent);background:var(--accent-soft)}
.addon .box{width:17px;height:17px;border-radius:5px;border:2px solid var(--hair);flex:none;position:relative}
.addon[data-on="1"] .box{border-color:var(--accent);background:var(--accent)}
.addon[data-on="1"] .box::after{content:"";position:absolute;left:4px;top:1px;width:4px;height:8px;border:2px solid #fff;border-top:0;border-left:0;transform:rotate(42deg)}
.addon .txt{flex:1;font-size:14.5px}
.addon .amt{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--slate)}
.summary{position:sticky;top:88px}
.summary .amount{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(36px,6vw,50px);letter-spacing:-.03em;margin:6px 0 4px}
.summary .sub{color:var(--slate);font-size:14px}
.summary ul{list-style:none;margin:22px 0 0;border-top:1px solid var(--hair);padding-top:18px;display:grid;gap:9px}
.summary li{display:flex;justify-content:space-between;gap:14px;font-size:14px;color:var(--slate)}
.summary li b{color:var(--ink);font-weight:500;font-family:'JetBrains Mono',monospace;font-size:13px}
.summary .foot-note{display:block;color:var(--slate);font-size:12.5px;margin-top:18px;border-top:1px solid var(--hair);padding-top:14px}

/* dynamic form */
.dfield{margin-bottom:18px}
.dfield label{display:block;font-size:13.5px;color:var(--slate);margin-bottom:7px}
.dfield select,.dfield input[type=text],.dfield input[type=tel]{
  width:100%;padding:13px 15px;border-radius:10px;background:var(--paper);
  border:1px solid var(--hair);color:var(--ink);font-size:15px;
}
.dfield select:focus,.dfield input:focus{outline:none;border-color:var(--accent)}
.dfield .hint{font-size:12.5px;color:var(--slate);margin-top:6px;min-height:18px}
.dfield .hint.ok{color:#1a9e5f}
.dfield .hint.no{color:#d94b4b}
.reveal{animation:slidein .28s cubic-bezier(.2,.7,.3,1)}
@keyframes slidein{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
.rangewrap{display:flex;align-items:center;gap:14px}
.rangewrap output{font-family:'JetBrains Mono',monospace;font-size:14px;color:var(--accent);min-width:52px;text-align:right}
.pills{display:flex;flex-wrap:wrap;gap:8px}
.pills button{border:1px solid var(--hair);border-radius:100px;padding:9px 15px;font-size:14px;color:var(--slate)}
.pills button[aria-pressed="true"]{background:var(--accent);border-color:var(--accent);color:#fff}
.demo-submit{width:100%;padding:14px;border-radius:100px;background:var(--ink);color:var(--paper);font-size:15px;font-weight:500;margin-top:6px}
.demo-note{display:block;text-align:center;color:var(--slate);font-size:12.5px;margin-top:10px}

/* ---------------- lab ---------------- */
.lab{display:grid;gap:16px}
@media(min-width:820px){.lab{grid-template-columns:repeat(3,1fr)}}
.lab h3{font-size:16px;margin-bottom:6px}
.lab .cap{color:var(--slate);font-size:13.5px;margin-bottom:18px}
.counter{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:42px;letter-spacing:-.03em;color:var(--accent)}
.acc{border-top:1px solid var(--hair)}
.acc details{border-bottom:1px solid var(--hair)}
.acc summary{list-style:none;padding:13px 0;font-size:14.5px;display:flex;justify-content:space-between;gap:10px;cursor:pointer}
.acc summary::-webkit-details-marker{display:none}
.acc summary::after{content:"+";color:var(--accent);font-family:'JetBrains Mono',monospace}
.acc details[open] summary::after{content:"−"}
.acc p{color:var(--slate);font-size:13.5px;padding-bottom:14px}
.lazyrow{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.lazyrow div{aspect-ratio:1/1;border-radius:8px;overflow:hidden}

/* ---------------- footer ---------------- */
footer{border-top:1px solid var(--hair);padding:54px 0 36px;font-size:14.5px}
.foot{display:grid;gap:26px}
@media(min-width:820px){.foot{grid-template-columns:1.5fr 1fr 1fr}}
.foot h4{margin-bottom:14px;color:var(--slate)}
.foot a{color:var(--slate);display:block;margin-bottom:9px}
.foot a:hover{color:var(--accent)}
.credit{border-top:1px solid var(--hair);margin-top:36px;padding-top:22px;color:var(--slate);font-size:13px;display:flex;flex-wrap:wrap;gap:10px;justify-content:space-between}
</style>
</head>
<body>

<header>
  <div class="wrap nav">
    <div class="brand">Three Sixty <i>Plus</i></div>
    <nav class="nav-links">
      <a href="#responsive">Every screen</a>
      <a href="#gallery">Dynamic gallery</a>
      <a href="#compare">Before / after</a>
      <a href="#pricing">Instant pricing</a>
      <a href="#form">Smart form</a>
      <a href="#lab">Details</a>
    </nav>
    <div class="themeswitch" id="themeSwitch" role="group" aria-label="Colour theme">
      <button data-mode="light" aria-pressed="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <span>Light</span>
      </button>
      <button data-mode="dark" aria-pressed="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
        <span>Dark</span>
      </button>
    </div>
  </div>
</header>

<main>

<!-- ================= HERO ================= -->
<section class="hero">
  <div class="wrap">
    <span class="mono eyebrow">A working demo — not a brochure</span>
    <h1>Most websites just sit there.</h1>
    <p class="lead">This page is a demonstration. Every component below is live — drag it, filter it, type into it. Each one exists because it removes a specific reason a visitor leaves without contacting you. The photography throughout is our own studio work.</p>

    <div class="forwho" style="margin-bottom:34px">
      <b>Your brand, your palette</b>
      <p style="width:100%;color:var(--slate);font-size:15px;margin:-2px 0 4px">A site is built in whatever colours your brand calls for — light, dark, or something in between. Try it on this page:</p>
      <div class="themeswitch" role="group" aria-label="Colour theme">
        <button data-mode="light" aria-pressed="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          <span>Light</span>
        </button>
        <button data-mode="dark" aria-pressed="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
          <span>Dark</span>
        </button>
      </div>
    </div>

    <div class="rig" id="responsive">
      <div class="rig-bar">
        <span class="mono">Screen width <b class="rig-read mono" id="wRead">1140px</b></span>
        <span class="mono" id="dRead">Desktop layout</span>
        <div class="rig-presets">
          <button data-w="380" class="mono">Phone</button>
          <button data-w="768" class="mono">Tablet</button>
          <button data-w="1140" class="mono" aria-pressed="true">Desktop</button>
        </div>
      </div>
      <input type="range" id="wRange" min="320" max="1140" value="1140" aria-label="Drag to resize the preview">
      <div class="rig-stage">
        <div class="viewport" id="viewport">
          <div class="mini-nav">
            <span class="mini-logo">Aurora Skincare</span>
            <span class="mini-menu"><span>Shop</span><span>About</span><span>Contact</span></span>
            <span class="mini-burger"><i></i><i></i><i></i></span>
          </div>
          <div class="mini-hero">
            <div>
              <h4>Skin that behaves itself.</h4>
              <p>Small-batch formulas, made without the marketing nonsense.</p>
              <span class="mini-pill">Shop the range</span>
            </div>
            <div class="mini-img"><img id="deviceImg" src="" alt="Product photography example"></div>
          </div>
          <div class="mini-cards">
            <div class="mini-card"><b>Cleansers</b><span>Daily wash &amp; balm</span></div>
            <div class="mini-card"><b>Serums</b><span>Targeted treatment</span></div>
            <div class="mini-card"><b>Sets</b><span>Full routines</span></div>
          </div>
