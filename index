const ADDONS = [
  {id:'a1', name:'Extra pages',            in:0, com:0},
  {id:'a2', name:'Product photography',    in:0, com:0},
  {id:'a3', name:'Logo & brand identity',  in:0, com:0},
  {id:'a4', name:'Monthly care & updates', in:0, com:0}
];

// conditional fields for the smart form
const FORM_FIELDS = {
  photo: [
    {k:'count', type:'range', label:'How many products?', min:1, max:100, val:12, suffix:''},
    {k:'style', type:'pills', label:'Background', options:['White / marketplace','Lifestyle','Dark &amp; moody'], val:0}
  ],
  web: [
    {k:'pages', type:'range', label:'Roughly how many pages?', min:1, max:30, val:6, suffix:''},
    {k:'sell',  type:'pills', label:'Selling online?', options:['No','Yes, a few products','Yes, full catalogue'], val:0}
  ],
  video: [
    {k:'length', type:'range', label:'Video length (seconds)', min:10, max:180, val:30, suffix:'s'},
    {k:'kind',   type:'pills', label:'Type', options:['Product demo','Brand film','Social cut-downs'], val:0}
  ],
  brand: [
    {k:'scope', type:'pills', label:'What do you need?', options:['Logo only','Logo + guidelines','Full identity'], val:1},
    {k:'stage', type:'pills', label:'Stage', options:['Brand new','Refresh'], val:0}
  ]
};
const SERVICE_NAMES = {photo:'Product photography', web:'Website design', video:'Video production', brand:'Branding & identity'};

/* ===================== behaviour ===================== */

// theme — visitor chooses; both switches stay in sync
const themeSwitches = document.querySelectorAll('.themeswitch');
function setTheme(mode){
  document.documentElement.dataset.theme = mode;
  themeSwitches.forEach(sw => sw.querySelectorAll('button').forEach(b =>
    b.setAttribute('aria-pressed', String(b.dataset.mode === mode))));
}
themeSwitches.forEach(sw => sw.addEventListener('click', e => {
  const b = e.target.closest('button'); if(b) setTheme(b.dataset.mode);
}));
setTheme(window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

// responsive rig
const wRange = document.getElementById('wRange'), viewport = document.getElementById('viewport'),
      wRead = document.getElementById('wRead'), dRead = document.getElementById('dRead'),
      presets = document.querySelectorAll('.rig-presets button');
function setWidth(px){
  const stage = viewport.parentElement.clientWidth - 24;
  viewport.style.width = Math.min(px, stage) + 'px';
  wRead.textContent = px + 'px';
  dRead.textContent = px < 560 ? 'Phone layout' : px < 900 ? 'Tablet layout' : 'Desktop layout';
  presets.forEach(b => b.setAttribute('aria-pressed', String(+b.dataset.w === px)));
}
wRange.addEventListener('input', e => setWidth(+e.target.value));
presets.forEach(b => b.addEventListener('click', () => { wRange.value = b.dataset.w; setWidth(+b.dataset.w); }));
window.addEventListener('resize', () => setWidth(+wRange.value));
setWidth(+wRange.value);
document.getElementById('deviceImg').src = img(DEVICE, 700, 700);

// gallery
const galEl = document.getElementById('gal'), filtersEl = document.getElementById('filters'),
      countEl = document.getElementById('galCount');
const cats = ['All', ...new Set(GALLERY.map(g => g.cat))];
let active = 'All';
filtersEl.innerHTML = cats.map(c => `<button data-cat="${c}" aria-pressed="${c === 'All'}">${c}</button>`).join('');
function renderGallery(){
  const list = GALLERY.filter(g => active === 'All' || g.cat === active);
  galEl.innerHTML = list.map((g, i) => `
    <figure class="tile" style="animation-delay:${i * 40}ms" data-i="${GALLERY.indexOf(g)}">
      <div class="frame"><img src="${img(g.id, 640, 640)}" alt="${g.title}" loading="lazy"></div>
      <figcaption><b>${g.title}</b><span class="mono">${g.cat}</span></figcaption>
    </figure>`).join('');
  countEl.textContent = `Showing ${list.length} of ${GALLERY.length} projects`;
}
filtersEl.addEventListener('click', e => {
  const b = e.target.closest('button'); if(!b) return;
  active = b.dataset.cat;
  filtersEl.querySelectorAll('button').forEach(x => x.setAttribute('aria-pressed', String(x === b)));
  renderGallery();
});
renderGallery();

// lightbox
const lb = document.getElementById('lb');
galEl.addEventListener('click', e => {
  const t = e.target.closest('.tile'); if(!t) return;
  const g = GALLERY[+t.dataset.i];
  document.getElementById('lbImg').src = img(g.id, 1000, 1000);
  document.getElementById('lbTitle').textContent = g.title;
  document.getElementById('lbCat').textContent = g.cat;
  lb.setAttribute('open','');
});
function closeLb(){ lb.removeAttribute('open'); }
document.getElementById('lbClose').addEventListener('click', closeLb);
lb.addEventListener('click', e => { if(e.target === lb) closeLb(); });
document.addEventListener('keydown', e => { if(e.key === 'Escape') closeLb(); });

// before / after
document.getElementById('baBefore').src = img(COMPARE.before, 900, 900);
document.getElementById('baAfter').src  = img(COMPARE.after, 900, 900);
document.getElementById('baL').textContent = COMPARE.beforeLabel;
document.getElementById('baR').textContent = COMPARE.afterLabel;
const ba = document.getElementById('ba');
ba.querySelector('input').addEventListener('input', e => ba.style.setProperty('--split', e.target.value + '%'));

// calculator
let cur = 'in', plan = 'basic';
const chosen = new Set();
const plansEl = document.getElementById('plans'), addonsEl = document.getElementById('addons');
const money = n => new Intl.NumberFormat(PLANS[cur].locale, {maximumFractionDigits:0}).format(n);
function renderCalc(){
  const P = PLANS[cur];
  plansEl.innerHTML = P.items.map(p => `
    <div class="plan" data-id="${p.id}" data-on="${p.id === plan ? 1 : 0}">
      <span class="dot"></span>
      <span class="txt"><b>${p.name}</b><span>${p.note}</span></span>
      <span class="amt">${P.symbol}${money(p.price)}</span>
    </div>`).join('');
  addonsEl.innerHTML = ADDONS.map(a => `
    <div class="addon" data-id="${a.id}" data-on="${chosen.has(a.id) ? 1 : 0}">
      <span class="box"></span><span class="txt">${a.name}</span>
      <span class="amt">${a[cur] ? '+ ' + P.symbol + money(a[cur]) : 'on request'}</span>
    </div>`).join('');
  const p = P.items.find(x => x.id === plan);
  let total = p.price + (p.setup || 0), onRequest = false;
  const lines = [{k:p.name, v:P.symbol + money(p.price)}];
  if(p.setup) lines.push({k:'One-time setup', v:P.symbol + money(p.setup)});
  ADDONS.forEach(a => {
    if(!chosen.has(a.id)) return;
    if(a[cur]){ total += a[cur]; lines.push({k:a.name, v:P.symbol + money(a[cur])}); }
    else { onRequest = true; lines.push({k:a.name, v:'on request'}); }
  });
  document.getElementById('totalAmt').textContent = P.symbol + money(total) + (onRequest ? '+' : '');
  document.getElementById('totalSub').textContent = onRequest ? p.name + ' — plus items quoted on request' : p.name;
  document.getElementById('breakdown').innerHTML = lines.map(l => `<li><span>${l.k}</span><b>${l.v}</b></li>`).join('');
}
document.getElementById('curSeg').addEventListener('click', e => {
  const b = e.target.closest('button'); if(!b) return;
  cur = b.dataset.cur;
  document.querySelectorAll('#curSeg button').forEach(x => x.setAttribute('aria-pressed', String(x === b)));
  renderCalc();
});
plansEl.addEventListener('click', e => { const el = e.target.closest('.plan'); if(el){ plan = el.dataset.id; renderCalc(); } });
addonsEl.addEventListener('click', e => {
  const el = e.target.closest('.addon'); if(!el) return;
  chosen.has(el.dataset.id) ? chosen.delete(el.dataset.id) : chosen.add(el.dataset.id);
  renderCalc();
});
renderCalc();

// dynamic form
const svcEl = document.getElementById('svc'), dynEl = document.getElementById('dynFields'),
      sumEl = document.getElementById('formSummary'), dPhone = document.getElementById('dPhone'),
      dHint = document.getElementById('dHint');
let svc = 'photo', state = {};

function buildFields(){
  state = {};
  dynEl.innerHTML = FORM_FIELDS[svc].map((f, i) => {
    state[f.k] = f.type === 'range' ? f.val : f.options[f.val];
    if(f.type === 'range'){
      return `<div class="dfield reveal" style="animation-delay:${i * 50}ms">
        <label for="r-${f.k}">${f.label}</label>
        <div class="rangewrap">
          <input type="range" id="r-${f.k}" data-k="${f.k}" data-suffix="${f.suffix}" min="${f.min}" max="${f.max}" value="${f.val}">
          <output id="o-${f.k}">${f.val}${f.suffix}</output>
        </div>
      </div>`;
    }
    return `<div class="dfield reveal" style="animation-delay:${i * 50}ms">
      <label>${f.label}</label>
      <div class="pills" data-k="${f.k}">
        ${f.options.map((o, n) => `<button type="button" data-v="${o}" aria-pressed="${n === f.val}">${o}</button>`).join('')}
      </div>
    </div>`;
  }).join('');
  renderSummary();
}
function renderSummary(){
  const rows = [{k:'Service', v:SERVICE_NAMES[svc]}];
  FORM_FIELDS[svc].forEach(f => {
    const raw = state[f.k];
    rows.push({k:f.label.replace('?',''), v: f.type === 'range' ? raw + (f.suffix || '') : raw});
  });
  const digits = dPhone.value.replace(/\D/g, '');
  rows.push({k:'Phone', v: digits.length === 10 ? digits : '—'});
  sumEl.innerHTML = rows.map(r => `<li><span>${r.k}</span><b>${r.v}</b></li>`).join('');
}
svcEl.addEventListener('change', () => { svc = svcEl.value; buildFields(); });
dynEl.addEventListener('input', e => {
  const r = e.target.closest('input[type=range]'); if(!r) return;
  state[r.dataset.k] = +r.value;
  document.getElementById('o-' + r.dataset.k).textContent = r.value + (r.dataset.suffix || '');
  renderSummary();
});
dynEl.addEventListener('click', e => {
  const b = e.target.closest('.pills button'); if(!b) return;
  const group = b.parentElement;
  group.querySelectorAll('button').forEach(x => x.setAttribute('aria-pressed', String(x === b)));
  state[group.dataset.k] = b.dataset.v;
  renderSummary();
});
dPhone.addEventListener('input', () => {
  const v = dPhone.value.replace(/\D/g, '');
  dHint.className = 'hint';
  if(!v.length) dHint.textContent = 'We check this as you type, so a typo never costs you a callback.';
  else if(v.length < 10){ dHint.textContent = `${10 - v.length} more digit${10 - v.length > 1 ? 's' : ''} to go`; dHint.classList.add('no'); }
  else if(v.length > 10){ dHint.textContent = 'That looks too long — check the number'; dHint.classList.add('no'); }
  else { dHint.textContent = 'Looks good — we can reach you there'; dHint.classList.add('ok'); }
  renderSummary();
});
document.getElementById('demoSend').addEventListener('click', () => {
  const note = document.getElementById('demoNote');
  note.textContent = 'Nothing sent — this page is a demonstration.';
  setTimeout(() => { note.textContent = 'This is a demo — nothing is submitted.'; }, 2600);
});
buildFields();

// counter
const c1 = document.getElementById('c1');
new IntersectionObserver((entries, obs) => {
  entries.forEach(en => {
    if(!en.isIntersecting) return;
    const to = +c1.dataset.to;
    const start = performance.now(), dur = 1100;
    (function step(now){
      const t = Math.min(1, (now - start) / dur);
      const eased = 1 - Math.pow(1 - t, 3);
      c1.innerHTML = Math.round(to * eased) + '<span style="opacity:' + (t === 1 ? 1 : 0) + '">+</span>';
      if(t < 1) requestAnimationFrame(step);
    })(start);
    obs.unobserve(en.target);
  });
}, {threshold:.6}).observe(c1);

// lazy row
document.getElementById('lazyRow').innerHTML =
  LAZY.map(id => `<div><img src="${img(id, 240, 240)}" alt="" loading="lazy"></div>`).join('');
</script>
</body>
